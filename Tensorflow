import tensorflow as tf
from tensorflow.keras import Sequential
from tensorflow.keras.layers import Dense
import numpy as np

# 1. Prepare simple data (OR Gate example)
X = np.array([[0,0], [0,1], [1,0], [1,1]], dtype=np.float32)
y = np.array([[0], [1], [1], [1]], dtype=np.float32)

# 2. Build the model
model = Sequential([
    # Input layer with 2 features, hidden layer with 4 neurons
    Dense(4, input_dim=2, activation='relu'), 
    # Output layer with 1 neuron (Sigmoid for binary output)
    Dense(1, activation='sigmoid')
])

# 3. Compile the model
model.compile(optimizer='adam', 
              loss='binary_crossentropy', 
              metrics=['accuracy'])

# 4. Train the model
model.fit(X, y, epochs=500, verbose=0) # verbose=0 hides training logs

# 5. Make a prediction
print("Prediction for [1, 1]:", model.predict([[1, 1]]).round())
